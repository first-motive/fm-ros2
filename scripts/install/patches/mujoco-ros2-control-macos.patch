diff --git a/mujoco_ros2_control/CMakeLists.txt b/mujoco_ros2_control/CMakeLists.txt
index 9e30a29..9a3f6f4 100644
--- a/mujoco_ros2_control/CMakeLists.txt
+++ b/mujoco_ros2_control/CMakeLists.txt
@@ -21,6 +21,16 @@ find_package(mujoco_ros2_control_msgs REQUIRED)
 find_package(mujoco_ros2_control_plugins REQUIRED)
 find_package(Threads REQUIRED)
 find_package(transmission_interface REQUIRED)
+# RoboStack's hardware_interface exports only <prefix>/include (Humble's flat header
+# layout) but generates version.h into the modern nested one,
+# <prefix>/include/hardware_interface/hardware_interface/version.h. So
+# `#include <hardware_interface/version.h>` cannot resolve through
+# hardware_interface_INCLUDE_DIRS. Locate the nested root and add it below.
+find_path(hardware_interface_NESTED_INCLUDE_DIR
+  NAMES hardware_interface/version.h
+  HINTS ${hardware_interface_INCLUDE_DIRS}
+  PATH_SUFFIXES hardware_interface
+)
 find_package(backward_ros REQUIRED)
 find_package(tinyxml2_vendor QUIET)
 find_package(TinyXML2 REQUIRED)
@@ -152,22 +162,44 @@ add_library(mujoco_ros2_control SHARED
 # Ensure MuJoCo library can be found at runtime regardless of how it was installed above.
 # mujoco_vendor installs libmujoco.so under opt/mujoco_vendor/lib/ relative to the
 # install prefix, so that directory must be in the RPATH alongside the standard lib/.
-set_target_properties(mujoco_ros2_control PROPERTIES
-  INSTALL_RPATH "\$ORIGIN/../lib;\$ORIGIN/../opt/mujoco_vendor/lib;${CMAKE_INSTALL_PREFIX}/lib"
-)
+if(APPLE)
+  # Mach-O spells the loader-relative prefix @loader_path, not $ORIGIN.
+  set_target_properties(mujoco_ros2_control PROPERTIES
+    INSTALL_RPATH "@loader_path/../lib;@loader_path/../opt/mujoco_vendor/lib;${CMAKE_INSTALL_PREFIX}/lib"
+  )
+else()
+  set_target_properties(mujoco_ros2_control PROPERTIES
+    INSTALL_RPATH "\$ORIGIN/../lib;\$ORIGIN/../opt/mujoco_vendor/lib;${CMAKE_INSTALL_PREFIX}/lib"
+  )
+endif()
+# Setting INSTALL_RPATH explicitly above replaces the rpath CMake would otherwise derive
+# from the link line. On apt Linux that is harmless — the loader finds librcl and friends
+# through ld.so.conf. In a conda/pixi env nothing is on a global search path, so every ROS
+# dylib must be reachable by rpath or the library dlopens to "@rpath/librcl.dylib not
+# loaded". Re-enable the derived entries so the env's lib dir is appended.
+set_target_properties(mujoco_ros2_control PROPERTIES INSTALL_RPATH_USE_LINK_PATH TRUE)
 # MuJoCo has TinyXML2 statically linked, which conflicts with the system TinyXML2
 # used by FastDDS. We need to ensure the system TinyXML2 is loaded first.
 # Force tinyxml2 to appear first in the DT_NEEDED entries by using LINK_OPTIONS.
 # TODO: Remove this after the following is resolved and the next ROS sync
 # https://github.com/pal-robotics/mujoco_vendor/issues/2
-target_link_options(mujoco_ros2_control PUBLIC
-  "LINKER:--push-state,--no-as-needed"
-  "$<TARGET_LINKER_FILE:tinyxml2::tinyxml2>"
-  "LINKER:--pop-state"
-)
+#
+# Mach-O has no DT_NEEDED and no --as-needed, so there is no load order to force and
+# ld rejects the flags outright. The conflict this guards against cannot arise here:
+# it is an ELF symbol-interposition artifact. Skip the block on Apple.
+if(NOT APPLE)
+  target_link_options(mujoco_ros2_control PUBLIC
+    "LINKER:--push-state,--no-as-needed"
+    "$<TARGET_LINKER_FILE:tinyxml2::tinyxml2>"
+    "LINKER:--pop-state"
+  )
+endif()
 target_link_libraries(mujoco_ros2_control
 PUBLIC
-  hardware_interface::hardware_interface
+  # RoboStack's Humble hardware_interface (2.51.0) predates ros2_control's namespaced
+  # target export (added in 2.54.0) and still exports the old ament variables. macOS is
+  # capped at 2.51.0 by the ros2-distro-mutex 0.7 pin, so use the variable form.
+  ${hardware_interface_LIBRARIES}
   rclcpp::rclcpp
   rclcpp_lifecycle::rclcpp_lifecycle
   ${nav_msgs_TARGETS}
@@ -194,7 +226,12 @@ target_include_directories(mujoco_ros2_control PUBLIC
   $<INSTALL_INTERFACE:include>
   $<INSTALL_INTERFACE:${MUJOCO_INSTALL_INCLUDE_DIR}>
   $<INSTALL_INTERFACE:${MUJOCO_INSTALL_SIMULATE_DIR}>
-  $<TARGET_PROPERTY:transmission_interface::transmission_interface,INTERFACE_INCLUDE_DIRECTORIES>
+  # transmission_interface (2.51.0) exports no namespaced target to read the property
+  # off; its ament variable carries the same include dirs. Headers only either way,
+  # which is what the note above requires.
+  ${transmission_interface_INCLUDE_DIRS}
+  ${hardware_interface_INCLUDE_DIRS}
+  ${hardware_interface_NESTED_INCLUDE_DIR}
   $<TARGET_PROPERTY:mujoco_ros2_control_plugins::mujoco_ros2_control_plugins,INTERFACE_INCLUDE_DIRECTORIES>
 )
 # Mark MuJoCo source as system to avoid compiler warnings
@@ -217,8 +254,13 @@ install(DIRECTORY include/ DESTINATION include)
 
 # Install the ROS 2 control node
 add_executable(ros2_control_node src/mujoco_ros2_control_node.cpp)
+# controller_manager (2.51.0) exports old-style ament variables, not a namespaced target.
 target_link_libraries(ros2_control_node PUBLIC
-  controller_manager::controller_manager
+  ${controller_manager_LIBRARIES}
+)
+target_include_directories(ros2_control_node PUBLIC
+  ${controller_manager_INCLUDE_DIRS}
+  ${hardware_interface_NESTED_INCLUDE_DIR}
 )
 install(
   TARGETS ros2_control_node

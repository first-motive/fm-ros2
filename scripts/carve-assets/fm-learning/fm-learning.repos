# vcs import < fm-learning.repos   (run from the workspace root)
#
# Siblings fm-data + fm-policy (track main) + lerobot.
repositories:
  src/fm-data:
    type: git
    url: https://github.com/first-motive/fm-data.git
    version: main
  src/fm-policy:
    type: git
    url: https://github.com/first-motive/fm-policy.git
    version: main
  external/lerobot:
    type: git
    url: https://github.com/huggingface/lerobot.git
    version: 741c2d0a3939ba54d6cf47f29a7fbbba3766a600

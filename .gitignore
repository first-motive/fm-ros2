# Planning notes (local only)
plans/

# MuJoCo runtime log (written to cwd on each sim run)
MUJOCO_LOG.TXT

# fm_tui viewer preference (written to the /ws mount on toggle; local only)
.fm_tui.json

# install profile: path (native|container) + viewer, written by install.sh
.fm_ros2.json

# Package repos pulled into the workspace (vcs import src < fm-ros2.repos)
src/

# Shared container infra, imported from fm-docker (vcs import < fm-ros2.repos)
docker/

# Private overlay manifest — kept out of the public repo
private-overlay.repos

# Vendored external sources (pulled via vcs import)
external/

# colcon build artifacts (root-anchored so scripts/install/ is not caught)
/build/
/install/
/log/

# pixi native env (materialized from pixi.lock; the manifest + lock are tracked)
.pixi/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store

/docker

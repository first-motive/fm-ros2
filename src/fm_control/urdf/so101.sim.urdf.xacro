<?xml version="1.0" encoding="utf-8"?>
<!--
First Motive SO101 description with a backend-selectable ros2_control System.

This merges the vendored TheRobotStudio SO101 geometry (the flat URDF installed into
fm_description's share) and injects First Motive's <ros2_control> system, selected by
`sim_backend`. The SO101 is a single fixed configuration, so there is no preset arg —
unlike the OpenArm, the variant is purely nominal.

Args:
  sim_backend   mock | mujoco | gazebo | isaac | real  (selects the System plugin)
  usb_port      serial device for the real (feetech) backend; ignored by sim backends
  mujoco_model  MJCF the mujoco backend loads; injected by the fm_bringup registry
                from fm_sim_models when sim_backend=mujoco (empty default otherwise)
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="so101">

  <xacro:arg name="sim_backend" default="mock"/>
  <xacro:arg name="usb_port" default="/dev/ttyACM0"/>
  <xacro:arg name="isaac_joint_commands_topic" default="/isaac_joint_commands"/>
  <xacro:arg name="isaac_joint_states_topic" default="/isaac_joint_states"/>
  <!-- MujocoSystemInterface reads the MJCF from a URDF <param>. The path is owned by
       fm_sim_models and injected by the fm_bringup registry; the default stays empty. -->
  <xacro:arg name="mujoco_model" default=""/>
  <xacro:property name="mujoco_model_path" value="$(arg mujoco_model)"/>
  <!-- Controllers file the Gazebo gz_ros2_control plugin loads; gazebo backend only. -->
  <xacro:arg name="gazebo_controllers_file" default=""/>

  <!-- Geometry: the vendored flat SO101 URDF, installed into fm_description's share.
       Its links/joints (bare names) merge into this robot. Mesh paths stay relative
       (assets/...); the description builder rewrites them to package:// at load. -->
  <xacro:include filename="$(find fm_description)/so101_description/so101_new_calib.urdf"/>
  <xacro:include filename="$(find fm_control)/urdf/so101.ros2_control.xacro"/>

  <xacro:so101_arm_system
      sim_backend="$(arg sim_backend)"
      usb_port="$(arg usb_port)"
      mujoco_model_path="${mujoco_model_path}"
      isaac_joint_commands_topic="$(arg isaac_joint_commands_topic)"
      isaac_joint_states_topic="$(arg isaac_joint_states_topic)"/>

  <!-- Gazebo hosts the controller_manager inside the sim via this world plugin,
       which loads the controllers.yaml. Emitted only for the gazebo backend. -->
  <xacro:if value="${'$(arg sim_backend)' == 'gazebo'}">
    <gazebo>
      <plugin filename="gz_ros2_control-system"
              name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(arg gazebo_controllers_file)</parameters>
      </plugin>
    </gazebo>
  </xacro:if>

</robot>

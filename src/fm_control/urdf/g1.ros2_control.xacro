<?xml version="1.0"?>
<!--
First Motive ros2_control for the Unitree G1-D arms + wheeled base.

One <ros2_control> system holds both arms (7 joints each) and the two drive wheels.
Two joint_trajectory_controllers each claim an arm's 7 joints (g1_right_arm_controller,
g1_left_arm_controller); a diff_drive_controller claims the two wheels' velocity
interface (g1_base_controller). The waist, legs, and hands are left unactuated here
(they hold at zero via robot_state_publisher in sim). Only the <hardware> System plugin
swaps, selected by `sim_backend`:

  mock    -> mock_components/GenericSystem               (no sim; perfect state echo)
  mujoco  -> mujoco_ros2_control/MujocoSystemInterface   (CPU)
  gazebo  -> gz_ros2_control/GazeboSimSystem             (Linux/GPU)
  isaac   -> topic_based_ros2_control/TopicBasedSystem   (Isaac Sim over ROS topics)

There is deliberately NO `real` ros2_control plugin: no hardware interface exists for
the G1 upstream. The real arms are driven by the Servo->arm_sdk bridge (a 50 Hz
unitree_hg/LowCmd loop on rt/arm_sdk) and the real base by g1_base_teleop (Twist ->
AGV Move RPC), which replace the controller + hardware at runtime — so for
sim_backend=real this macro emits no <ros2_control> at all, leaving the description
geometry-only for robot_state_publisher. See the bridge nodes.

Joint names match the vendored g1_d URDF exactly. arm_sdk motor_cmd indices: right arm
22..28, left arm 15..21 (unitree_sdk2 JointIndex enum). The wheels (Left_Wheel_Joint,
Right_Wheel_Joint) are velocity-controlled in sim only.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="g1_backend_hardware"
      params="sim_backend mujoco_model_path
              isaac_joint_commands_topic isaac_joint_states_topic">

    <xacro:if value="${sim_backend == 'mock'}">
      <hardware>
        <plugin>mock_components/GenericSystem</plugin>
        <param name="fake_sensor_commands">false</param>
        <param name="state_following_offset">0.0</param>
      </hardware>
    </xacro:if>

    <xacro:if value="${sim_backend == 'mujoco'}">
      <hardware>
        <plugin>mujoco_ros2_control/MujocoSystemInterface</plugin>
        <param name="mujoco_model">${mujoco_model_path}</param>
      </hardware>
    </xacro:if>

    <xacro:if value="${sim_backend == 'gazebo'}">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>
    </xacro:if>

    <xacro:if value="${sim_backend == 'isaac'}">
      <hardware>
        <plugin>topic_based_ros2_control/TopicBasedSystem</plugin>
        <param name="joint_commands_topic">${isaac_joint_commands_topic}</param>
        <param name="joint_states_topic">${isaac_joint_states_topic}</param>
      </hardware>
    </xacro:if>
  </xacro:macro>

  <!-- One joint: position/velocity/effort command + state, uniform across the sim
       backends so the controller set never changes. -->
  <xacro:macro name="g1_arm_joint" params="joint_name">
    <joint name="${joint_name}">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="effort">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
  </xacro:macro>

  <!-- One drive wheel: velocity command + position/velocity state, claimed by the
       diff_drive_controller. -->
  <xacro:macro name="g1_wheel_joint" params="joint_name">
    <joint name="${joint_name}">
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
  </xacro:macro>

  <!-- The dual-arm + wheeled-base system (14 arm joints + 2 wheels), emitted for sim
       backends only. -->
  <xacro:macro name="g1_system"
      params="sim_backend mujoco_model_path:=''
              isaac_joint_commands_topic:=/isaac_joint_commands
              isaac_joint_states_topic:=/isaac_joint_states">

    <xacro:unless value="${sim_backend == 'real'}">
      <ros2_control name="g1_system" type="system">
        <xacro:g1_backend_hardware
            sim_backend="${sim_backend}"
            mujoco_model_path="${mujoco_model_path}"
            isaac_joint_commands_topic="${isaac_joint_commands_topic}"
            isaac_joint_states_topic="${isaac_joint_states_topic}" />

        <xacro:g1_arm_joint joint_name="right_shoulder_pitch_joint"/>
        <xacro:g1_arm_joint joint_name="right_shoulder_roll_joint"/>
        <xacro:g1_arm_joint joint_name="right_shoulder_yaw_joint"/>
        <xacro:g1_arm_joint joint_name="right_elbow_joint"/>
        <xacro:g1_arm_joint joint_name="right_wrist_roll_joint"/>
        <xacro:g1_arm_joint joint_name="right_wrist_pitch_joint"/>
        <xacro:g1_arm_joint joint_name="right_wrist_yaw_joint"/>

        <xacro:g1_arm_joint joint_name="left_shoulder_pitch_joint"/>
        <xacro:g1_arm_joint joint_name="left_shoulder_roll_joint"/>
        <xacro:g1_arm_joint joint_name="left_shoulder_yaw_joint"/>
        <xacro:g1_arm_joint joint_name="left_elbow_joint"/>
        <xacro:g1_arm_joint joint_name="left_wrist_roll_joint"/>
        <xacro:g1_arm_joint joint_name="left_wrist_pitch_joint"/>
        <xacro:g1_arm_joint joint_name="left_wrist_yaw_joint"/>

        <xacro:g1_wheel_joint joint_name="Left_Wheel_Joint"/>
        <xacro:g1_wheel_joint joint_name="Right_Wheel_Joint"/>
      </ros2_control>
    </xacro:unless>
    <!-- real: no ros2_control; the Servo->arm_sdk bridge drives the arms and
         g1_base_teleop drives the base at runtime. -->
  </xacro:macro>

</robot>
